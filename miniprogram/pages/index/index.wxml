<!--pages/index/index.wxml-->
<view class="container">
  <!-- Logo区域 -->
  <view class="logo-section">
    <view class="logo">
      <text class="logo-icon">⚡</text>
    </view>
    <view class="title">火电机组考核系统</view>
    <view class="subtitle">热工自动化在线考试平台</view>
  </view>

  <!-- 角色选择卡片 -->
  <view class="role-cards">
    <!-- 学生入口 -->
    <view class="role-card" bindtap="goToStudent">
      <view class="role-icon student-icon">
        <text>👨‍🎓</text>
      </view>
      <view class="role-info">
        <view class="role-title">学生考试</view>
        <view class="role-desc">在线答题、查看成绩</view>
      </view>
      <view class="role-arrow">›</view>
    </view>

    <!-- 教师入口 -->
    <view class="role-card" bindtap="goToTeacher">
      <view class="role-icon teacher-icon">
        <text>👨‍🏫</text>
      </view>
      <view class="role-info">
        <view class="role-title">教师管理</view>
        <view class="role-desc">题库管理、统计分析</view>
      </view>
      <view class="role-arrow">›</view>
    </view>
  </view>

  <!-- 系统信息 -->
  <view class="system-info">
    <view class="info-item">
      <text class="info-label">题库数量</text>
      <text class="info-value">244题</text>
    </view>
    <view class="info-divider"></view>
    <view class="info-item">
      <text class="info-label">在线学生</text>
      <text class="info-value">70人</text>
    </view>
    <view class="info-divider"></view>
    <view class="info-item">
      <text class="info-label">考试章节</text>
      <text class="info-value">20章</text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version">
    <text>v1.0.0 | 技术支持：Coze AI</text>
  </view>
</view>
