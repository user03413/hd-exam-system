/* app.wxss - 全局样式 */

/* 页面容器 */
.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding: 20rpx;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 按钮样式 */
.btn-primary {
  background-color: #1a73e8;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary:active {
  background-color: #1557b0;
}

.btn-success {
  background-color: #34a853;
  color: #ffffff;
}

.btn-warning {
  background-color: #fbbc04;
  color: #ffffff;
}

.btn-danger {
  background-color: #ea4335;
  color: #ffffff;
}

/* 文本样式 */
.text-primary {
  color: #1a73e8;
}

.text-success {
  color: #34a853;
}

.text-danger {
  color: #ea4335;
}

.text-warning {
  color: #fbbc04;
}

.text-muted {
  color: #999999;
}

.text-center {
  text-align: center;
}

/* 标题样式 */
.title {
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 30rpx;
}

/* 表单样式 */
.input {
  background-color: #f8f9fa;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
}

.input:focus {
  border-color: #1a73e8;
}

/* 章节标签 */
.chapter-tag {
  display: inline-block;
  background-color: #e3f2fd;
  color: #1565c0;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

/* 题型标签 */
.type-tag {
  display: inline-block;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.type-single {
  background-color: #e3f2fd;
  color: #1565c0;
}

.type-multiple {
  background-color: #fff3e0;
  color: #e65100;
}

.type-short {
  background-color: #e8f5e9;
  color: #2e7d32;
}

/* 难度标签 */
.diff-easy {
  color: #34a853;
}

.diff-medium {
  color: #fbbc04;
}

.diff-hard {
  color: #ea4335;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
  margin-left: 16rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  color: #e0e0e0;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
}
