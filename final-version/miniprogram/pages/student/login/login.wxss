/* pages/student/login/login.wxss */

.container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding: 60rpx 40rpx;
}

/* 顶部信息 */
.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #1a73e8 0%, #1557b0 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
  font-size: 60rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: #999999;
}

/* 章节信息 */
.chapter-info {
  background: #e3f2fd;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
}

.chapter-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.chapter-text {
  font-size: 30rpx;
  color: #1565c0;
  font-weight: 500;
}

/* 登录表单 */
.login-form {
  margin-bottom: 40rpx;
}

.input {
  background-color: #ffffff;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 30rpx;
  font-size: 32rpx;
  margin-bottom: 30rpx;
}

.input:focus {
  border-color: #1a73e8;
}

.login-btn {
  width: 100%;
  background-color: #1a73e8;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.login-btn[disabled] {
  background-color: #cccccc;
}

/* 提示信息 */
.tips {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #666666;
  line-height: 50rpx;
}
