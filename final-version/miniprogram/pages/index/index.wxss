/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a73e8 0%, #1557b0 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-top: 80rpx;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 40rpx;
}

.logo-icon {
  font-size: 80rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 角色卡片 */
.role-cards {
  width: 100%;
  margin-bottom: 60rpx;
}

.role-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.role-card:active {
  transform: scale(0.98);
}

.role-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  margin-right: 30rpx;
}

.student-icon {
  background: #e3f2fd;
}

.teacher-icon {
  background: #fff3e0;
}

.role-info {
  flex: 1;
}

.role-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 10rpx;
}

.role-desc {
  font-size: 26rpx;
  color: #999999;
}

.role-arrow {
  font-size: 60rpx;
  color: #cccccc;
  font-weight: 300;
}

/* 系统信息 */
.system-info {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 30rpx 50rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.info-item {
  text-align: center;
}

.info-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 10rpx;
}

.info-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.info-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* 版本信息 */
.version {
  margin-top: auto;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}
